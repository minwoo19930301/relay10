{
  "name": "disciplinedrun",
  "version": "0.2.0",
  "description": "DisciplinedRun — a lightweight coding-agent harness with risk-aware effort, inspectable evidence, and separate verdicts. (formerly Relay10)",
  "type": "module",
  "bin": {
    "disciplinedrun": "./src/cli.mjs",
    "relay10": "./src/cli.mjs",
    "r10": "./src/cli.mjs"
  },
  "scripts": {
    "check": "npm run test && npm run lint && npm run validate:skills",
    "test": "node --test test/*.test.mjs",
    "lint": "node --check src/*.mjs && node --check test/*.mjs && node --check scripts/*.mjs",
    "smoke": "node src/cli.mjs doctor && node src/cli.mjs route \"research and build a small CLI\" --json",
    "validate:skills": "node scripts/validate-skill-pack.mjs",
    "verify:package": "node scripts/verify-packed-package.mjs",
    "report:launch": "node scripts/build-launch-report.mjs",
    "audit:launch": "node scripts/audit-launch-report.mjs",
    "verify:launch": "node scripts/verify-launch.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "disciplinedrun",
    "relay10",
    "codex",
    "claude-code",
    "grok",
    "agent-skills",
    "agent-harness",
    "model-routing",
    "effort-governor",
    "evidence-led",
    "multi-agent",
    "clarity-eval"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/minwoo19930301/relay10.git"
  },
  "bugs": {
    "url": "https://github.com/minwoo19930301/relay10/issues"
  },
  "homepage": "https://github.com/minwoo19930301/relay10#readme",
  "files": [
    "src",
    "schema",
    "examples",
    "test",
    "scripts",
    "docs",
    "plugins/relay10",
    ".claude-plugin",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "CHANGELOG.md"
  ]
}
